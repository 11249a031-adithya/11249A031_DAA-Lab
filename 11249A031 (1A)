#include <stdio.h>
int fibonacci_series (int n)
{
if (n==0)
{
return 0;
}
else if (n==1|n==2)
{
return 1;
}
else
return fibonacci_series (n-1)+fibonacci_series (n-2);

}
int main()
{
int i;
printf("Enter a number:");
scanf("%d",&i);
printf("The %dth term of the fibonacci series is: %d",i,fibonacci_series (i));
return 0;
}
